# Cài đặt lib

import cv2
import matplotlib.pyplot as plt
import os
import glob
from inference_sdk import InferenceHTTPClient

print("lib imported!")

# 1. Đường dẫn đến thư mục chứa ảnh gốc
# Lưu ý: Vì file notebook nằm trong thư mục 'notebooks/', 
# nên ta dùng '../' để lùi lại 1 bước ra ngoài rồi mới vào 'data/raw/'
RAW_DATA_DIR = "../data/raw/"

# Lấy danh sách tất cả file .jpg trong thư mục raw
image_files = glob.glob(os.path.join(RAW_DATA_DIR, "*.jpg"))

if len(image_files) == 0:
    print("Không tìm thấy ảnh nào trong thư mục data/raw/!")
else:
    # Lấy bức ảnh đầu tiên tìm được
    test_image_path = image_files[0]
    print(f"Đang hiển thị ảnh: {test_image_path}")
    
    # Đọc ảnh bằng OpenCV
    img = cv2.imread(test_image_path)
    
    # OpenCV mặc định đọc hệ màu BGR (Blue-Green-Red), 
    # ta cần chuyển sang RGB để matplotlib hiển thị đúng màu thật
    img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
    
    # Hiển thị ảnh
    plt.figure(figsize=(10, 8))
    plt.imshow(img_rgb)
    plt.axis('off') # Ẩn trục tọa độ
    plt.title("Ảnh gốc chưa xử lý")
    plt.show()

# 1. Kết nối với Roboflow API
CLIENT = InferenceHTTPClient(
    api_url="https://detect.roboflow.com",
    api_key="NHẬP_API_KEY_CỦA_BẠN_VÀO_ĐÂY" 
)

# 2. Thay đổi thông tin model của bạn
WORKSPACE_NAME = "ten-workspace-cua-ban"
MODEL_ID = "ten-project/1" # Ví dụ: "find-tomato-oohfb/1"

print("Đang gửi ảnh lên AI để nhận diện...")

try:
    # 3. Chạy nhận diện
    # Bạn có thể dùng hàm infer nếu dùng model object detection tiêu chuẩn
    result = CLIENT.infer(test_image_path, model_id=MODEL_ID)
    
    # In ra kết quả JSON thô máy chủ trả về
    print("AI đã trả về kết quả!")
    print(result)
    
    predictions = result['predictions']
    print(f"\nPhát hiện được {len(predictions)} quả trong ảnh.")
    
except Exception as e:
    print(f"Có lỗi xảy ra khi gọi API: {e}")
