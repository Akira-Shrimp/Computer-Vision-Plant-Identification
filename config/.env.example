# ╔══════════════════════════════════════════════════════════════╗
# ║  Plant Vision — Environment Configuration                   ║
# ║  Copy this file to ../.env and fill in your values           ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Roboflow API ──────────────────────────────────────────────
ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_API_KEY=YOUR_API_KEY_HERE
ROBOFLOW_WORKFLOW=find-tomato-oohfb
ROBOFLOW_WORKSPACE=h-m-0hina
ROBOFLOW_PLAN=webrtc-gpu-medium
ROBOFLOW_REGION=us

# ── Camera ────────────────────────────────────────────────────
CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# ── Detection ─────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.5
TARGET_CLASSES=tomato_ripe,pepper_ripe
ALL_CLASSES=tomato_green,tomato_ripe,pepper_green,pepper_ripe

# ── Robot / Serial ────────────────────────────────────────────
SERIAL_PORT=COM3
SERIAL_BAUD=9600
SERIAL_TIMEOUT=1
ROBOT_SIMULATION=true
ROBOT_MIN_X=0
ROBOT_MAX_X=1280
ROBOT_MIN_Y=0
ROBOT_MAX_Y=720
ROBOT_COMMAND_DELAY=0.5

# ── Growth Tracking ──────────────────────────────────────────
GROWTH_CAPTURE_INTERVAL=3600

# ── Data Collection ──────────────────────────────────────────
AUTO_CAPTURE_INTERVAL=5

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
DASHBOARD_DEBUG=false

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
